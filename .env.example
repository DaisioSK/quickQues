# ============================================================
# j-contract environment template
# ============================================================
# Copy to `.env` and fill values. `.env` is gitignored.
# NEVER commit real API keys. Pre-commit hook will block common patterns.
# Loaded centrally via src/jcontract/config.py (DECISION-0.2.1 dev-sprint).
# ============================================================

# ----- LLM / Vision: Claude (Anthropic) -----
# Primary Answerer + Vision captioner (Phase 1 S1.4, Phase 4 S4.1)
ANTHROPIC_API_KEY=

# ----- LLM fallback: DeepSeek -----
# Answerer failover (Phase 4 S4.2)
DEEPSEEK_API_KEY=

# ----- PDF Parsing: LlamaParse (LlamaIndex) -----
# Primary PDFParser (Phase 1 S1.2)
LLAMA_CLOUD_API_KEY=

# ----- Vector DB: Qdrant -----
# Self-hosted via docker-compose; URL points to the qdrant service.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ----- App config -----
APP_PORT=8000
LOG_LEVEL=INFO
