# ============================================================
# j-contract environment template
# ============================================================
# Copy to `.env` and fill values. `.env` is gitignored.
# NEVER commit real API keys. Pre-commit hook will block common patterns.
# Loaded centrally via src/jcontract/config.py (DECISION-0.2.1 dev-sprint).
# ============================================================

# ----- LLM / Vision: Claude (Anthropic) -----
# Primary Answerer + Vision captioner (Phase 1 S1.4, Phase 4 S4.1)
ANTHROPIC_API_KEY=

# ----- LLM fallback: DeepSeek -----
# Answerer failover (Phase 4 S4.2)
DEEPSEEK_API_KEY=

# ----- Local LLM: any OpenAI-compatible endpoint (--answerer local) -----
# Defaults target an Ollama server on localhost — zero data egress.
# The key is a placeholder: Ollama ignores it but the openai SDK
# requires a non-empty string. Set a real key only for remote endpoints.
JCONTRACT_LOCAL_LLM_BASE_URL=http://localhost:11434/v1
JCONTRACT_LOCAL_LLM_MODEL=qwen3:14b
JCONTRACT_LOCAL_LLM_API_KEY=ollama

# ----- Local VLM: Ollama drawing captioner (--caption-backend ollama) -----
# Server address WITHOUT /v1 (the impl appends the OpenAI-compat suffix).
# No API key: Ollama ignores auth. Pull the model first: `ollama pull qwen3-vl:8b`.
JCONTRACT_OLLAMA_BASE_URL=http://localhost:11434
JCONTRACT_OLLAMA_VL_MODEL=qwen3-vl:8b

# ----- Embedding: batch size (memory bound) -----
# fastembed batch size for embedding calls. Default 256 (fastembed's own
# default). Lower it (e.g. 16) on low-RAM hosts: onnxruntime activation
# memory scales with batch_size x longest sequence in the batch — batch 256
# with bge-m3 full-page chunks peaked ~15GB RSS (OOM-killed on a 16GB host).
JCONTRACT_EMBED_BATCH=256

# ----- Redaction: reversible pseudonymization (redact-preview, ssDI) -----
# Mechanism only — not wired into ingest. Both files live in YOUR project
# data directory, never in this repo. The mapping store is the RESTORE KEY:
# gitignore it, never log it. Empty defaults = the command fails fast with
# a clear message unless you pass --dictionary/--map-store explicitly.
JCONTRACT_REDACTION_DICT=
JCONTRACT_REDACTION_MAP=

# ----- Dispatch: provider pool for dispatch-plan (ssMP) -----
# Comma-separated provider NAMES for the deterministic hash lottery
# (dry-run only — names are never instantiated, nothing is called).
# No default on purpose: the pool is your routing config, not ours.
# Pool ORDER is part of the assignment rule — reordering reassigns pages.
JCONTRACT_DISPATCH_POOL=

# ----- PDF Parsing: LlamaParse (LlamaIndex) -----
# Primary PDFParser (Phase 1 S1.2)
LLAMA_CLOUD_API_KEY=

# ----- Vector DB: Qdrant -----
# Self-hosted via docker-compose; URL points to the qdrant service.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ----- App config -----
APP_PORT=8000
LOG_LEVEL=INFO
