input-docs/**/*.pdf
input-docs/**/*.PDF

# ----- WeChat reference screenshots in repo root (legacy) -----
/*.pic.jpg

# ----- uv -----
# uv.lock IS committed per DECISION-0.2.1.
# Caches are not.
.uv_cache/
/.claude/

# ----- web/ (Next.js frontend, sub-sprint p5-s2-ssNextInit) -----
# package-lock.json IS committed for reproducible installs (Node analog
# of uv.lock). node_modules / build artifacts / test caches are not.
web/node_modules/
web/.next/
web/coverage/
web/.turbo/
web/out/
